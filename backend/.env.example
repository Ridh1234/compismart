APIFY_YOUTUBE_SHORTS_ACTOR=streamers/youtube-shorts-scraper
APIFY_YOUTUBE_SHORTS_MAX_RESULTS=50
COHERE_API_KEY=
CHROMA_PERSIST_DIR=./.chroma
COHERE_CHAT_MODEL=command-a-plus-05-2026
